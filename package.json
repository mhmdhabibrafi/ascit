{
  "name": "ascit",
  "version": "1.0.0",
  "private": true,
  "description": "ASCIT - Asset Care Information Technology System",
  "scripts": {
    "dev": "next dev --turbo",
    "dev:flyenv": "npm run flyenv:db:setup && next dev --turbo",
    "build": "next build",
    "start": "next start",
    "start:flyenv": "npm run flyenv:db:setup && next start",
    "serve:flyenv": "npm run db:setup && npm run build && npm run start:flyenv",
    "lint": "eslint .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:setup": "npm run flyenv:db:setup && npm run prisma:generate && npx prisma migrate dev && npm run prisma:seed && npm run db:health",
    "db:status": "npx prisma migrate status",
    "db:health": "node scripts/db-health.mjs",
    "flyenv:db:start": "node scripts/flyenv-postgres.mjs start",
    "flyenv:db:stop": "node scripts/flyenv-postgres.mjs stop",
    "flyenv:db:status": "node scripts/flyenv-postgres.mjs status",
    "flyenv:db:setup": "node scripts/flyenv-postgres.mjs setup",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:seed": "prisma db seed"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.10.0",
    "@hookform/resolvers": "^3.10.0",
    "@prisma/client": "^6.11.1",
    "@zxing/browser": "^0.2.0",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "exceljs": "^4.4.0",
    "lucide-react": "^0.468.0",
    "next": "^15.3.4",
    "next-auth": "^4.24.11",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.58.1",
    "react-is": "^19.0.0",
    "recharts": "^2.15.4",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.1",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.21",
    "dbgate-serve": "^7.2.1",
    "dotenv": "^17.4.2",
    "eslint": "^9.29.0",
    "eslint-config-next": "^15.3.4",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.5.0",
    "postcss": "8.5.16",
    "prisma": "^6.11.1",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.4.11",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^0.34.6"
  },
  "overrides": {
    "postcss": "8.5.16",
    "react-is": "$react-is",
    "uuid": "^11.1.1"
  }
}
